# =========================================
# Inventory System Environment Variables
# =========================================
# Copy this file to .env and configure with your values
# SECURITY: Never commit .env to version control

# -------------------------
# Application Settings
# -------------------------
APP_NAME=Jules Inventory

# SECURITY CRITICAL: Generate a secure secret key
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-here-change-this

# Environment (development, staging, production)
ENVIRONMENT=development

# Enable strict configuration validation in production
STRICT_CONFIG_VALIDATION=false

# -------------------------
# Database Configuration
# -------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/jules_inventory

# -------------------------
# Redis Configuration
# -------------------------
# Redis connection string for background job queue
REDIS_URL=redis://localhost:6379/0

# -------------------------
# S3/MinIO Storage
# -------------------------
# S3-compatible storage endpoint
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION_NAME=us-east-1
BUCKET_MEDIA=inventory-media
BUCKET_DOCS=inventory-docs

# -------------------------
# AI Configuration
# -------------------------
# Jarvis AI host base URL (loaded from config/ai_host.env)
JARVIS_BASE_URL=

# -------------------------
# Security Settings
# -------------------------
# Session token expiry in seconds (default: 86400 = 24 hours)
TOKEN_EXPIRY_SECONDS=86400

# AI confidence thresholds (0.0-1.0)
# Auto-apply AI changes above this confidence level
AI_AUTO_APPLY_CONFIDENCE=0.95

# Require manual review below this threshold
AI_MANUAL_REVIEW_THRESHOLD=0.80

# -------------------------
# Optional Settings
# -------------------------
# Test mode (uses FakeRedis)
# TEST_MODE=false
